# =================================================================
# Bella Knowledge Docker Compose Configuration - Example
# =================================================================
# Copy this file to .env and modify the values as needed

# =================================================================
# Maven Mirror Configuration
# =================================================================
# Options: central (Maven Central), aliyun (Aliyun Mirror)
MAVEN_MIRROR=aliyun

# =================================================================
# MySQL Configuration
# =================================================================
MYSQL_CONTAINER_NAME=bella-file-api-mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=bella_file_api
MYSQL_USER=bella_user
MYSQL_PASSWORD=change_this_password_123
MYSQL_ROOT_PASSWORD=change_this_root_password
EXPOSE_MYSQL_PORT=3306

# =================================================================
# Redis Configuration
# =================================================================
REDIS_CONTAINER_NAME=bella-file-api-redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# =================================================================
# API Configuration
# =================================================================
API_HOST=localhost
API_PORT=8081
API_MIN_HEAP=1024m
API_MAX_HEAP=2048m
API_METASPACE=256m
API_MAX_METASPACE=512m
LOG_PATH=../api/logs

# Spring Configuration
SPRING_PROFILES_ACTIVE=docker

# Bella Configuration
BELLA_OPEN_API_BASE=https://localhost:8080/
BELLA_STORAGE_TYPE=local

# Proxy Configuration (Optional)
PROXY_HOST=
PROXY_PORT=
PROXY_TYPE=
STORAGE_CONFIG=

# =================================================================
# Web Configuration
# =================================================================
WEB_PORT=3001
ALLOWED_DEV_ORIGINS=

# =================================================================
# Nginx Configuration
# =================================================================
NGINX_CONTAINER_NAME=bella-file-api-nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =================================================================
# Docker Registry Configuration
# =================================================================
REGISTRY=bellatop
VERSION=latest

# =================================================================
# General Configuration
# =================================================================
TZ=Asia/Shanghai