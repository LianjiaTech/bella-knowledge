# ============================================================================
# Bella File API Enterprise Configuration
# ============================================================================

# ============================================================================
# Basic Configuration
# ============================================================================
TZ=Asia/Shanghai
SPRING_PROFILES_ACTIVE=docker,enterprise

# ============================================================================
# MySQL Configuration
# ============================================================================
MYSQL_CONTAINER_NAME=bella-file-api-mysql
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=bella_file_api
MYSQL_USER=bella_user
MYSQL_PASSWORD=123456
MYSQL_ROOT_PASSWORD=root
EXPOSE_MYSQL_PORT=3306

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_CONTAINER_NAME=bella-file-api-redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=bella123

# ============================================================================
# S3 Configuration (MinIO implementation)
# ============================================================================
S3_CONTAINER_NAME=bella-file-api-minio
S3_HOST=minio
S3_API_PORT=9000
S3_CONSOLE_PORT=9001
S3_ACCESS_KEY=bella_user
S3_SECRET_KEY=12345678
S3_BUCKET=bella-file-api
S3_ROOT_PATH=files
S3_REGION=us-east-1

# Application S3 Configuration
BELLA_STORAGE_TYPE=s3

# ============================================================================
# Kafka Configuration (KRaft mode - no Zookeeper)
# ============================================================================
KAFKA_HOST=kafka
KAFKA_ENABLED=true
KAFKA_EXTERNAL_HOST=localhost
EXPOSE_KAFKA_PLAINTEXT_PORT=9092
EXPOSE_KAFKA_CONTROLLER_PORT=9093
EXPOSE_KAFKA_EXTERNAL_PORT=19092

# Kafka Application Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PRODUCER_VALUE_SERIALIZER=org.springframework.kafka.support.serializer.JsonSerializer
KAFKA_PRODUCER_KEY_SERIALIZER=org.apache.kafka.common.serialization.StringSerializer
KAFKA_TOPIC_BROADCAST=bella_file_api

# ============================================================================
# Kafka Configuration
# ============================================================================
KAFKA_CONTAINER_NAME=bella-file-api-kafka

# ============================================================================
# Kafka UI Configuration
# ============================================================================
KAFKA_UI_CONTAINER_NAME=bella-file-api-kafka-ui
KAFKA_UI_PORT=8080

# ============================================================================
# Application Services Configuration
# ============================================================================
API_CONTAINER_NAME=bella-file-api
API_PORT=8081
API_HOST=bella-file-api
WEB_CONTAINER_NAME=bella-file-web
WEB_PORT=3001

# Java Heap Configuration
API_MIN_HEAP=2048m
API_MAX_HEAP=4096m
API_METASPACE=512m
API_MAX_METASPACE=1024m

# ============================================================================
# Nginx Configuration
# ============================================================================
NGINX_CONTAINER_NAME=bella-file-api-nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SERVER_DOMAIN=localhost
SERVER_PROTOCOL=https

# SSL Configuration
ENABLE_SSL=true
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/private.key

# ============================================================================
# Application Configuration
# ============================================================================
BELLA_OPEN_API_BASE=https://localhost/
BELLA_TMP_FILE_DIR=/opt/bella-file-api/cache
LOG_PATH=../api/logs

# Proxy Configuration (if needed)
PROXY_HOST=
PROXY_PORT=
PROXY_TYPE=

# Storage Configuration
STORAGE_CONFIG=

# Development Configuration
ALLOWED_DEV_ORIGINS=

# ============================================================================
# Docker Image Configuration
# ============================================================================
REGISTRY=bellatop
VERSION=latest
MAVEN_MIRROR=aliyun